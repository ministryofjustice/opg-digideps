{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "enabled": true,
  "timezone": "Europe/London",

  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],

  "branchPrefix": "renovate/",
  "labels": ["dependencies", "renovate"],
  "rebaseWhen": "conflicted",
  "dependencyDashboard": true,
  "branchConcurrentLimit": 5,
  "prHourlyLimit": 2,

  "minimumReleaseAge": "7 days",

  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "labels": ["dependencies", "renovate", "major"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchPackagePatterns": ["*"],
      "isVulnerabilityAlert": true,
      "labels": ["dependencies", "renovate", "security"],
      "prPriority": 10,
      "prCreation": "immediate"
    },
    {
      "description": ["Docker Minor Dependency Exclusions - PHP"],
      "matchUpdateTypes": ["minor"],
      "matchDatasources": ["docker"],
      "matchDepNames": ["php"],
      "enabled": false
    },
    {
      "description": ["Disable Docker digest-only updates"],
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    },
    {
      "groupName": "Docker image updates",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "docker"],
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions"],
      "automerge": true,
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "groupName": "Node.js dependency updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "node"],
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "groupName": "PHP dependency updates",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "php"],
      "matchDepTypes": ["dependencies", "require"],
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "groupName": "PHP dev dependency updates",
      "matchManagers": ["composer"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dev-dependencies", "php"],
      "matchDepTypes": ["require-dev"],
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "groupName": "Python dependency updates",
      "matchManagers": ["pip_requirements", "pip-compile"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "python"],
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["pip_requirements", "pip-compile"],
      "rangeStrategy": "bump"
    },
    {
      "groupName": "Golang dependency updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["dependencies", "golang"],
      "schedule": ["before 9am on Monday"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["php"],
      "matchUpdateTypes": ["minor"],
      "enabled": false
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchDatasources": ["docker"],
      "matchPackageNames": ["python"],
      "matchUpdateTypes": ["minor"],
      "enabled": false
    }
  ]
}
