ignore:
  SNYK-CC-TF-127:
    - '*':
        reason: "MFA delete intentionally disabled to avoid breaking service accounts"

  SNYK-CC-TF-45:
    - '*':
        reason: "S3 access logging intentionally disabled because this bucket is development-only and only contains dev data"

  SNYK-CC-TF-55:
    - '*':
        reason: "SNS encryption intentionally not enabled because Can't do cross region SNS encryption"
  SNYK-CC-TF-214:
    - '*':
        reason: "ElastiCache in-transit encryption intentionally disabled due to known performance impact: see DDPB-3661"
  SNYK-CC-AWS-428:
    - '*':
        reason: "VPC endpoint policy intentionally omitted. Access is restricted by security groups and IAM. Adding policy could break the VPC without constantly updating it."
