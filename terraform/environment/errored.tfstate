    {
      "module": "module.eu_west_1[0].module.pa_uploads",
      "mode": "data",
      "type": "aws_iam_policy_document",
      "name": "bucket",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"].digideps_eu_west_1",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "839334864",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Id\": \"PutObjPolicy\",\n  \"Statement\": [\n    {\n      \"Sid\": \"DenyUnEncryptedObjectUploads\",\n      \"Effect\": \"Deny\",\n      \"Action\": \"s3:PutObject\",\n      \"Resource\": \"arn:aws:s3:::pa-uploads-preproduction/*\",\n      \"Principal\": {\n        \"AWS\": \"*\"\n      },\n      \"Condition\": {\n        \"StringNotEquals\": {\n          \"s3:x-amz-server-side-encryption\": \"AES256\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"DenyNoneSSLRequests\",\n      \"Effect\": \"Deny\",\n      \"Action\": \"s3:*\",\n      \"Resource\": [\n        \"arn:aws:s3:::pa-uploads-preproduction/*\",\n        \"arn:aws:s3:::pa-uploads-preproduction\"\n      ],\n      \"Principal\": {\n        \"AWS\": \"*\"\n      },\n      \"Condition\": {\n        \"Bool\": {\n          \"aws:SecureTransport\": \"false\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"DelegateS3Access\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:ListBucket\",\n        \"s3:GetObject\"\n      ],\n      \"Resource\": [\n        \"arn:aws:s3:::pa-uploads-preproduction/*\",\n        \"arn:aws:s3:::pa-uploads-preproduction\"\n      ],\n      \"Principal\": {\n        \"AWS\": \"arn:aws:iam::238302996107:root\"\n      }\n    }\n  ]\n}",
            "override_policy_documents": null,
            "policy_id": "PutObjPolicy",
            "source_policy_documents": null,
            "statement": [
              {
                "actions": ["s3:PutObject"],
                "condition": [
                  {
                    "test": "StringNotEquals",
                    "values": ["AES256"],
                    "variable": "s3:x-amz-server-side-encryption"
                  }
                ],
                "effect": "Deny",
                "not_actions": [],
                "not_principals": [],
                "not_resources": [],
                "principals": [
                  {
                    "identifiers": ["*"],
                    "type": "AWS"
                  }
                ],
                "resources": ["arn:aws:s3:::pa-uploads-preproduction/*"],
                "sid": "DenyUnEncryptedObjectUploads"
              },
              {
                "actions": ["s3:*"],
                "condition": [
                  {
                    "test": "Bool",
                    "values": ["false"],
                    "variable": "aws:SecureTransport"
                  }
                ],
                "effect": "Deny",
                "not_actions": [],
                "not_principals": [],
                "not_resources": [],
                "principals": [
                  {
                    "identifiers": ["*"],
                    "type": "AWS"
                  }
                ],
                "resources": [
                  "arn:aws:s3:::pa-uploads-preproduction",
                  "arn:aws:s3:::pa-uploads-preproduction/*"
                ],
                "sid": "DenyNoneSSLRequests"
              },
              {
                "actions": ["s3:GetObject", "s3:ListBucket"],
                "condition": [],
                "effect": "Allow",
                "not_actions": [],
                "not_principals": [],
                "not_resources": [],
                "principals": [
                  {
                    "identifiers": ["arn:aws:iam::238302996107:root"],
                    "type": "AWS"
                  }
                ],
                "resources": [
                  "arn:aws:s3:::pa-uploads-preproduction",
                  "arn:aws:s3:::pa-uploads-preproduction/*"
                ],
                "sid": "DelegateS3Access"
              }
            ],
            "version": "2012-10-17"
          },
          "sensitive_attributes": []
        }
      ]
    },
