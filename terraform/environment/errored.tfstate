      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "id": "f2577798-18c8-41c0-a8a5-5ca1fb11c4be",
            "log_group_names": ["preproduction"],
            "name": "Business Analytics/preproduction sign up matching errors",
            "query_definition_id": "f2577798-18c8-41c0-a8a5-5ca1fb11c4be",
            "query_string": "fields @timestamp\n| parse @message \"search_terms\\\":{\\\"caseNumber\\\":\\\"*\\\",\\\"clientLastname\" as case_number\n| parse @message \"matching_errors\\\":{*}\" as matching_errors\n| parse matching_errors \"client_lastname\\\":*,\\\"deputy_lastname\\\":*,\\\"deputy_postcode\\\":*\" as client_lastname, deputy_lastname, deputy_postcode\n| filter @message like 'matching_errors'\n| sort @timestamp desc\n| display @timestamp, case_number, client_lastname, deputy_lastname, deputy_postcode, @message\n"
          },
          "sensitive_attributes": [],
          "private": "bnVsbA==",
          "dependencies": [
            "module.eu_west_1.aws_cloudwatch_log_group.opg_digi_deps",
