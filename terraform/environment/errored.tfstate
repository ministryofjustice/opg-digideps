            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"AllowReplicationConfiguration\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:ListBucket\",\n        \"s3:GetReplicationConfiguration\",\n        \"s3:GetObjectVersionTagging\",\n        \"s3:GetObjectVersionForReplication\",\n        \"s3:GetObjectVersionAcl\",\n        \"s3:GetObjectRetention\",\n        \"s3:GetObjectLegalHold\"\n      ],\n      \"Resource\": [\n        \"arn:aws:s3:::pa-uploads-preproduction/*\",\n        \"arn:aws:s3:::pa-uploads-preproduction\"\n      ]\n    },\n    {\n      \"Sid\": \"AllowReplication\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:ReplicateTags\",\n        \"s3:ReplicateObject\",\n        \"s3:ReplicateDelete\",\n        \"s3:ObjectOwnerOverrideToBucketOwner\",\n        \"s3:GetObjectVersionTagging\"\n      ],\n      \"Resource\": [\n        \"arn:aws:s3:::preproduction.backup.digideps.opg.service.justice.gov.uk/*\",\n        \"arn:aws:s3:::pa-uploads-branch-replication/*\"\n      ],\n      \"Condition\": {\n        \"StringLikeIfExists\": {\n          \"s3:x-amz-server-side-encryption\": [\n            \"aws:kms\",\n            \"AES256\"\n          ],\n          \"s3:x-amz-server-side-encryption-aws-kms-key-id\": \"arn:aws:kms:eu-west-1:238302996107:key/5875b77a-043c-41e3-a3c6-84bdd865fedf\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"Decrypt\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"kms:Decrypt\",\n      \"Resource\": \"arn:aws:kms:eu-west-1:454262938596:key/52a0d5db-5c8a-482e-b57d-02d616f1c330\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"kms:EncryptionContext:aws:s3:arn\": \"arn:aws:s3:::pa-uploads-preproduction/*\",\n          \"kms:ViaService\": \"s3.eu-west-1.amazonaws.com\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"Encrypt\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"kms:Encrypt\",\n      \"Resource\": \"arn:aws:kms:eu-west-1:238302996107:key/5875b77a-043c-41e3-a3c6-84bdd865fedf\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"kms:EncryptionContext:aws:s3:arn\": \"arn:aws:s3:::preproduction.backup.digideps.opg.service.justice.gov.uk/*\",\n          \"kms:ViaService\": \"s3.eu-west-1.amazonaws.com\"\n        }\n      }\n    }\n  ]\n}",
            "override_policy_documents": null,
            "policy_id": null,
            "source_policy_documents": null,
            "statement": [
              {
                "actions": [
