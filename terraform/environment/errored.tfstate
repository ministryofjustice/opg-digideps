                "sid": "AllowReplicationConfiguration"
              },
              {
                "actions": [
                  "s3:GetObjectVersionTagging",
                  "s3:ObjectOwnerOverrideToBucketOwner",
                  "s3:ReplicateDelete",
                  "s3:ReplicateObject",
