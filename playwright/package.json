{
  "name": "opg-digideps-end-to-end-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for Digideps: Managed by opg-org-infra &amp; Terraform",
  "scripts": {
    "lint": "eslint .",
    "check-format": "prettier --check .",
    "format": "prettier --write .",
    "test": "playwright test",
