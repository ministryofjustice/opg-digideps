    "show-report": "playwright show-report --host 0.0.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "3.8.3",
    "typescript-eslint": "^8.57.1"
  }
}
