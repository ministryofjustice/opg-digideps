{
    "name": "digideps/api",
    "license": "MIT",
    "type": "project",
    "description": "The \"Symfony Standard Edition\" distribution",
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.21"
        },
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "scripts": {
        "lint:phpstan": "phpstan",
        "lint:phpstan:baseline": "phpstan && phpstan --generate-baseline",
        "lint:phpstan:baseline:force": "phpstan --generate-baseline"
    },
    "autoload": {
        "psr-4": {
            "OPG\\Digideps\\Backend\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\OPG\\Digideps\\Backend\\": "tests/",
            "Tests\\OPG\\Digideps\\Backend\\Behat\\": "tests/Behat/bootstrap/"
        }
    },
    "require": {
        "ext-openssl": "*",
        "aws/aws-sdk-php": "^3.385.1",
        "digideps/common": "^1.0",
        "doctrine/doctrine-bundle": "^2.18.3",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/orm": "^2.20.13",
        "fakerphp/faker": "^1.24.1",
        "gbprod/uuid-normalizer": "^7.0.2",
        "jms/serializer-bundle": "^5.5.2",
        "lcobucci/jwt": "^4.3",
        "league/csv": "^9.28.0",
        "monolog/monolog": "^3.10.0",
        "predis/predis": "^3.5.1",
        "ramsey/uuid": "^4.9.3",
        "ramsey/uuid-doctrine": "^1.8.2",
        "stof/doctrine-extensions-bundle": "^1.15.3",
        "symfony/cache": "^6.4.41",
        "symfony/config": "^6.4.37",
        "symfony/console": "^6.4.41",
        "symfony/dependency-injection": "^6.4.38",
        "symfony/doctrine-bridge": "^6.4.34",
        "symfony/dotenv": "^6.4.39",
        "symfony/error-handler": "^6.4.36",
        "symfony/event-dispatcher": "^6.4.37",
        "symfony/expression-language": "^6.4.32",
        "symfony/filesystem": "^6.4.39",
        "symfony/finder": "^6.4.34",
        "symfony/form": "^6.4.36",
        "symfony/framework-bundle": "^6.4.41",
        "symfony/http-foundation": "^6.4.41",
        "symfony/http-kernel": "^6.4.41",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/password-hasher": "^6.4.32",
        "symfony/process": "^6.4.41",
        "symfony/property-info": "^6.4.34",
        "symfony/routing": "^6.4.41",
        "symfony/security-bundle": "^6.4.41",
        "symfony/security-core": "^6.4.41",
        "symfony/security-csrf": "^6.4.31",
        "symfony/security-http": "^6.4.41",
        "symfony/serializer": "^6.4.37",
        "symfony/validator": "^6.4.37",
        "symfony/yaml": "^6.4.41"
    },
    "require-dev": {
        "behat/behat": "^3.31",
        "behat/gherkin": "^4.17.0",
        "behat/mink": "^1.13",
        "behat/mink-browserkit-driver": "^2.3.0",
        "behat/mink-selenium2-driver": "^1.7",
        "dg/bypass-finals": "^1.10.2",
        "doctrine/doctrine-fixtures-bundle": "^3.7.3",
        "friends-of-behat/mink-extension": "^2.7.5",
        "friends-of-behat/symfony-extension": "^2.6.2",
        "guzzlehttp/guzzle": "^7.12.1",
        "jangregor/phpstan-prophecy": "^2.3",
        "liuggio/fastest": "^1.14.2",
        "mockery/mockery": "^1.6.12",
        "osteel/openapi-httpfoundation-testing": "^0.14.0",
        "phpspec/prophecy-phpunit": "^2.5.0",
        "phpstan/phpstan": "^2.2.2",
        "phpstan/phpstan-mockery": "^2.0.0",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpunit/phpcov": "^9.0.2",
        "phpunit/phpunit": "^10.5.63",
        "symfony/browser-kit": "^6.4.32",
        "symfony/http-client": "^6.4.41",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/mime": "^6.4.41",
        "symfony/phpunit-bridge": "^6.4.35",
        "symfony/var-dumper": "^6.4.36"
    },
    "minimum-stability": "stable",
    "extra": {
        "symfony-app-dir": "app",
        "symfony-web-dir": "web",
        "symfony": {
            "require": "6.*"
        }
    },
    "repositories": [
        {
            "url": "https://github.com/ministryofjustice/MinkExtension.git",
            "type": "git"
        },
        {
            "type": "path",
            "url": "../../common",
            "options": {
                "versions": {
                    "digideps/common": "1.0.0"
                }
            }
        }
    ]
}
