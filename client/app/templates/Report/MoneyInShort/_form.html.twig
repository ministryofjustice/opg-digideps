{% import '@App/Macros/macros.html.twig' as macros %}

{{ form_start(form, {attr: {novalidate: 'novalidate'} }) }}

    {{ form_input(form.description, 'form.transactionsIn.description', {
        'formGroupClass': 'explanation',
    }) }}
    {{ form_input(form.amount, 'form.transactionsIn.amount', {
        'inputPrefix' : '£',
        'inputClass' : 'govuk-!-width-one-quarter js-more-info js-format-currency',
        'formGroupClass': ' form-group-value'
    }) }}

    {{ form_known_date(form.date, 'form.transactionsIn.date', { required: false }) }}

    {% if form.addAnother %}
        {{ form_add_another({
            'addAnother': form.addAnother,
            'thingTranslationKey': 'form.thing',
            'translationDomain': translationDomain
        }) }}
    {% endif %}

    {{ macros.saveAndContinueButton(form.save) }}

{{ form_end(form) }}
