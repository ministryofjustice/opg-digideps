{% set append104 = report.get104TransSuffix %}
{% set page = 'summaryPage' %}
<h2 class="govuk-heading-m">Contacts</h2>

<div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
        <h3 class="govuk-summary-card__title govuk-!-width-one-half">
            Question
        </h3>
        <h3 class="govuk-summary-card__title govuk-!-width-one-half">
            Answer
        </h3>
    </div>

    <div class="govuk-summary-card__content">
        <table class="govuk-table">
            <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header govuk-!-width-one-half">
                        {{ 'existPage.form.hasContacts.label' | trans(transOptions,transDomain)  }}
                    </th>
                    <td class="govuk-table__cell govuk-!-width-one-half">
                        {{ (report.hasContacts) ? report.hasContacts | capitalize : 'not entered' }}
                    </td>
                </tr>
                {% if report.reasonForNoContacts %}
                    <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header govuk-!-width-one-half">
                            {{ 'existPage.form.headingReasonForNoContacts.label' | trans({},transDomain)  }}
                        </th>
                        <td class="govuk-table__cell govuk-!-width-one-half">
                            {{ report.reasonForNoContacts | nl2br }}
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>

{% if report.contacts | length > 0 %}
    <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
            <h3 class="govuk-summary-card__title">
                {{ (page ~ '.listOfContacts') | trans({},transDomain) }}
            </h3>
        </div>
        <div class="govuk-summary-card__content">
            <table class="govuk-table">
                <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header govuk-!-width-one-third">
                        {{ (page ~ '.contact') | trans({},transDomain) }}
                    </th>
                    <th scope="col" class="govuk-table__header govuk-!-width-one-third">
                        {{ (page ~ '.relationship') | trans({},transDomain) }}
                    </th>
                    <th scope="col" class="govuk-table__header govuk-!-width-one-third">
                        {{ (page ~ '.reasonForContact') | trans({},transDomain) }}
                    </th>
                </tr>
                </thead>
                <tbody class="govuk-table__body">
                    {% for contact in report.contacts %}
                        <tr class="govuk-table__row">
                            <td class="govuk-table__cell govuk-!-width-one-third">
                                <p class="govuk-!-margin-0 govuk-!-font-size-18">{{ contact.contactName }}</p>
                                {% if contact.address %}
                                    <p class="govuk-!-margin-0 govuk-!-font-size-16">{{ contact.address }}</p>
                                {% endif %}
                                {% if contact.address2 %}
                                    <p class="govuk-!-margin-0 govuk-!-font-size-16">{{ contact.address2 }}</p>
                                {% endif %}
                                {% if contact.county %}
                                    <p class="govuk-!-margin-0 govuk-!-font-size-16">{{ contact.county }}</p>
                                {% endif %}
                                {% if contact.postcode %}
                                    <p class="govuk-!-margin-0 govuk-!-font-size-16">{{ contact.postcode }}</p>
                                {% endif %}
                                {% if contact.country %}
                                    <p class="govuk-!-margin-0 govuk-!-font-size-16">{{ contact.country | country_name }}</p>
                                {% endif %}
                            </td>
                            <td class="govuk-table__cell govuk-!-width-one-third">
                                {{ contact.relationship }}
                            </td>
                            <td class="govuk-table__cell govuk-!-width-one-third">
                                {{ contact.explanation }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endif %}
