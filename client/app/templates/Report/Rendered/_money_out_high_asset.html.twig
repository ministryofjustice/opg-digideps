{% set page = 'summaryPage' %}
{% set review = 'review' %}
<h2 class="govuk-heading-m">
    {{ (review ~ '.moneyOut.question') | trans(transOptions, transDomain) }}
</h2>

<div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
        <h3 class="govuk-summary-card__title govuk-!-width-one-half">
            {{ (review ~ '.moneyOut.question') | trans(transOptions, transDomain) }}
        </h3>
        <h3 class="govuk-summary-card__title govuk-!-width-one-half">
            {{ (review ~ '.moneyOut.answer') | trans(transOptions, transDomain) }}
        </h3>
    </div>

    <div class="govuk-summary-card__content">
        <table class="govuk-table">
            <tbody class="govuk-table__body">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header govuk-!-width-one-half">
                        {{ (page ~ '.moneyOut.hasMoneyOut.label') | trans(transOptions, transDomain) }}
                    </th>
                    <td class="govuk-table__cell govuk-!-width-one-half">
                        {{ (report.moneyOutExists) ? report.moneyOutExists | capitalize : 'Not entered' }}
                    </td>
                </tr>

                {% if report.moneyOutExists == 'No' %}
                    <tr class="govuk-table__row">
                        <th scope="col" class="govuk-table__header govuk-!-width-one-half">
                            {{ (page ~ '.moneyOut.reasonForNoMoneyOut.label') | trans(transOptions, transDomain) }}
                        </th>
                        <td class="govuk-table__cell govuk-!-width-one-half">
                            {{ (report.reasonForNoMoneyOut) ? report.reasonForNoMoneyOut | capitalize : 'Not entered' }}
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>

{% if report.moneyOutExists == 'Yes' and report.moneyTransactionsOut | length > 0 %}
    <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
            <h3 class="govuk-summary-card__title govuk-!-width-one-half">
                {{ (review ~ '.moneyOut.payments') | trans(transOptions, transDomain) }}
            </h3>
        </div>
        <div class="govuk-summary-card__content">
            {% for categoryId, transactionGroup in report.groupMoneyTransactionsByGroup(report.moneyTransactionsOut) %}
                {% set total = 0 %}
                <h4 class="govuk-heading-s">
                    {{ ('form.group.entries.' ~ categoryId) | trans(transOptions, transDomain) }}
                </h4>
                <table class="govuk-table govuk-!-static-margin-top-1">
                    <thead class="govuk-table__head">
                        <tr class="govuk-table__row">
                            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">
                                {{ (page ~ '.moneyOut.list.label.type') | trans(transOptions, transDomain) }}
                            </th>
                            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">
                                {{ (page ~ '.moneyOut.list.label.description') | trans(transOptions, transDomain) }}
                            </th>
                            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">
                                {{ (page ~ '.moneyOut.list.label.bankAccount') | trans(transOptions, transDomain) }}
                            </th>
                            <th scope="col" class="govuk-table__header govuk-!-width-one-quarter">
                                {{ (page ~ '.moneyOut.list.label.amount') | trans(transOptions, transDomain) }}
                            </th>
                        </tr>
                    </thead>
                    <tbody class="govuk-table__body">
                    {% for transaction in transactionGroup.entries %}
                        {% set total = total + transaction.amount  %}
                        <tr class="govuk-table__row">
                            <td class="govuk-table__cell govuk-!-width-one-quarter">
                                {{ ('form.category.entries.' ~ transaction.category ~ '.label') | trans(transOptions, transDomain) }}
                            </td>
                            <td class="govuk-table__cell govuk-!-width-one-quarter">
                                {{ transaction.description | nl2br }}
                            </td>
                            <td class="govuk-table__cell govuk-!-width-one-quarter">
                                {{ (transaction.bankAccount) ? transaction.bankAccount.nameOneLine : 'Not entered' | trans({}, 'common') }}
                            </td>
                            <td class="govuk-table__cell govuk-!-width-one-quarter">
                                &pound;{{ transaction.amount | money_format }}
                            </td>
                        </tr>
                    {% endfor %}
                    <tr class="govuk-table__row">
                        <td class="govuk-summary-card__title govuk-!-width-one-quarter">
                            {{ (review ~ '.moneyOut.totalAmount') | trans(transOptions, transDomain) }}
                        </td>
                        <td class="govuk-table__cell govuk-!-width-one-quarter"></td>
                        <td class="govuk-table__cell govuk-!-width-one-quarter"></td>
                        <td class="govuk-summary-card__title govuk-!-width-one-quarter">
                            &pound;{{ total | money_format }}
                        </td>
                    </tr>
                    </tbody>
                </table>
            {% endfor %}

            <div class="govuk-grid-row govuk-heading-s">
                <div class="govuk-grid-column-three-quarters govuk-!-padding-right-0">
                    {{ (review ~ '.moneyOut.totalMoneyOut') | trans(transOptions, transDomain) }}
                </div>
                <div class="govuk-grid-column-one-quarter govuk-!-padding-left-0">
                    &pound;{{ report.getMoneyOutTotal | money_format }}
                </div>
            </div>
        </div>
    </div>
{% endif %}
