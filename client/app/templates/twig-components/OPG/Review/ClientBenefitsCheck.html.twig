<twig:GOV:Heading size="m" h="2">
    {{ text.header }}
</twig:GOV:Heading>

<twig:GOV:Summary:QaCard h="3">
    <twig:GOV:Summary:List list="{{ list }}"/>
</twig:GOV:Summary:QaCard>

{% if table is not null %}
    <twig:GOV:Summary:Card h="3" header="{{ text.tableHeader }}">
        <twig:GOV:Table table="{{ table }}"/>
    </twig:GOV:Summary:Card>
{% endif %}
