{% props id, n, h, summary=null, heading %}
{% set h_tag = "h" ~ h %}

<div class="govuk-accordion__section-header">
    <{{ h_tag }} class="govuk-accordion__section-heading">
        <span class="govuk-accordion__section-button" id="{{ id }}-header-{{ n }}">
            {{ heading }}
        </span>
    </{{ h_tag }}>
    {% if summary is not null %}
    <div class="govuk-accordion__section-summary govuk-body" id="{{ id }}-summary-{{ n }}">
        {{ summary }}
    </div>
    {% endif %}
</div>
