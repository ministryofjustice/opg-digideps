<twig:Heading size="m" h="2">
    {{ text.header }}
</twig:Heading>

<twig:Summary:QaCard h="3">
    <twig:Summary:List list="{{ list }}"/>
</twig:Summary:QaCard>

{% if tables|length > 0 %}
    <twig:Summary:Card h="3" header="{{ text.tableHeader }}">
        {% for table in tables %}
        <twig:Table table="{{ table }}"/>
        {% endfor %}
    </twig:Summary:Card>
{% endif %}
