{% props questionLabel="Question", answerLabel="Answer" %}
{% props h='1' %}{# 1 / 2 / 3 / 4 / 5 / 6 #}

{% set class = "govuk-heading-" ~ size %}
{% set h_tag = "h" ~ h %}

<div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
        <twig:Summary:Header h="{{ h }}" class="govuk-!-width-one-half">
            {{ questionLabel }}
        </twig:Summary:Header>
        <twig:Summary:Header h="{{ h }}" class="govuk-!-width-one-half">
            {{ answerLabel }}
        </twig:Summary:Header>
    </div>
    <div class="govuk-summary-card__content">
        <twig:block name="content"></twig:block>
    </div>
</div>
