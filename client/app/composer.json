{
    "name": "symfony/framework-standard-edition",
    "license": "MIT",
    "type": "project",
    "description": "The \"Symfony Standard Edition\" distribution",
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.21"
        },
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "lint:phpstan": "phpstan",
        "lint:phpstan:baseline": "phpstan && phpstan --generate-baseline",
        "lint:phpstan:baseline:force": "phpstan --generate-baseline"
    },
    "autoload": {
        "psr-4": {
            "OPG\\Digideps\\Frontend\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\OPG\\Digideps\\Frontend\\": "tests/"
        }
    },
    "require": {
        "ext-dom": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "alphagov/notifications-php-client": "^7.1.0",
        "aws/aws-sdk-php": "^3.385.1",
        "digideps/common": "^1.0",
        "doctrine/annotations": "^2.0.2",
        "doctrine/collections": "^2.6.0",
        "egulias/email-validator": "^4.0.4",
        "fakerphp/faker": "^1.24.1",
        "gbprod/uuid-normalizer": "^7.0.2",
        "guzzlehttp/guzzle": "^7.12.0",
        "jms/serializer-bundle": "^5.5.2",
        "jolicode/slack-php-api": "^4.9",
        "league/mime-type-detection": "^1.16",
        "monolog/monolog": "^3.10.0",
        "orbitale/imagemagick-php": "^3.3.5",
        "php-http/guzzle7-adapter": "^1.1",
        "predis/predis": "^3.5.1",
        "ramsey/uuid": "^4.9.3",
        "symfony/asset": "^6.4.34",
        "symfony/cache": "^6.4.41",
        "symfony/config": "^6.4.37",
        "symfony/console": "^6.4.41",
        "symfony/debug-bundle": "^6.4.35",
        "symfony/dependency-injection": "^6.4.38",
        "symfony/dotenv": "^6.4.39",
        "symfony/error-handler": "^6.4.36",
        "symfony/event-dispatcher": "^6.4.37",
        "symfony/expression-language": "^6.4.32",
        "symfony/form": "^6.4.36",
        "symfony/framework-bundle": "^6.4.41",
        "symfony/http-client": "^6.4.41",
        "symfony/http-foundation": "^6.4.41",
        "symfony/http-kernel": "^6.4.41",
        "symfony/intl": "^6.4.36",
        "symfony/lock": "^6.4.37",
        "symfony/mime": "^6.4.41",
        "symfony/monolog-bundle": "^3.11.2",
        "symfony/options-resolver": "^6.4.30",
        "symfony/property-info": "^6.4.34",
        "symfony/rate-limiter": "^6.4.41",
        "symfony/routing": "^6.4.41",
        "symfony/security-bundle": "^6.4.41",
        "symfony/security-core": "^6.4.41",
        "symfony/security-csrf": "^6.4.31",
        "symfony/security-http": "^6.4.41",
        "symfony/serializer": "^6.4.37",
        "symfony/translation": "^6.4.38",
        "symfony/twig-bundle": "^6.4.32",
        "symfony/uid": "^6.4.32",
        "symfony/validator": "^6.4.37",
        "symfony/web-profiler-bundle": "^6.4.41",
        "twig/extra-bundle": "^3.24",
        "twig/intl-extra": "^3.26",
        "web-token/jwt-framework": "^3.4.10"
    },
    "minimum-stability": "stable",
    "extra": {
        "symfony-app-dir": "app",
        "branch-alias": {
            "dev-master": "2.3-dev"
        },
        "symfony": {
            "require": "6.*"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://govuk-frontend-toolkit.appspot.com"
        },
        {
            "type": "path",
            "url": "../../common",
            "options": {
                "versions": {
                    "digideps/common": "1.0.0"
                }
            }
        }
    ],
    "require-dev": {
        "dg/bypass-finals": "^1.10.2",
        "jangregor/phpstan-prophecy": "^2.3.0",
        "league/openapi-psr7-validator": "^0.24.0",
        "mockery/mockery": "^1.6.12",
        "phpspec/prophecy-phpunit": "^2.5",
        "phpstan/phpstan": "^2.2.2",
        "phpstan/phpstan-mockery": "^2.0.0",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpunit/phpcov": "^8.2.1",
        "phpunit/phpunit": "^9.6.34",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/phpunit-bridge": "^6.4.35",
        "symfony/var-dumper": "^6.4.36"
    }
}
